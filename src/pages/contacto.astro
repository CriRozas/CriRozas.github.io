---
// src/pages/contacto.astro
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <section class="py-20 bg-white" id="contacto">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-semibold mb-12">Contacto</h2>

      <p class="mb-6 text-gray-700">
        <a
          href="https://wa.me/34674266191?text=Hola%20quiero%20información%20sobre%20los%20servicios%20de%20CRI%20las%20Rozas"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-green-500 text-white px-6 py-3 rounded-lg hover:bg-green-600 transition"
        >
          Contactar por WhatsApp
        </a>
      </p>

      <p class="mb-6 text-gray-700">
        Email:
        <a
          href="mailto:centrorehabilitacionintegral@gmail.com"
          class="text-blue-600 font-semibold"
        >
          centrorehabilitacionintegral@gmail.com
        </a>
      </p>

      <p class="mb-6 text-gray-700">
        Dirección:
        <a
          href="https://www.google.com/maps/dir//CRI+LAS+ROZAS+%22Centro+de+Rehabilitaci%C3%B3n+Integral%22+.,+C%2FDE+LA+ESTACION,+22,+28231+Las+Rozas+de+Madrid,+Madrid/@40.4946661,-3.8749155,15.5z/data=!4m17!1m7!3m6!1s0xd41837941856ab9:0xcd42ae59964a50ad!2sCRI+LAS+ROZAS+%22Centro+de+Rehabilitaci%C3%B3n+Integral%22+.!8m2!3d40.495018!4d-3.8695894!16s%2Fg%2F1tx48bh5!4m8!1m0!1m5!1m1!1s0xd41837941856ab9:0xcd42ae59964a50ad!2m2!1d-3.869585!2d40.4950097!3e0?entry=ttu&g_ep=EgoyMDI2MDIxNi4wIKXMDSoASAFQAw%3D%3D"
          target="_blank"
          class="text-blue-600 font-semibold hover:underline"
        >
          C/DE LA ESTACION, 22, 28231 Las Rozas de Madrid, Madrid
        </a>
      </p>

      <div class="flex justify-center gap-4 mb-8 flex-wrap">

        <!-- YouTube -->
        <a
          href="https://www.youtube.com/@crilasrozas"
          target="_blank"
          class="flex items-center justify-center w-12 h-12 bg-red-600 hover:bg-red-700 text-white rounded-full transition"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-6 h-6"
            fill="white"
            viewBox="0 0 24 24"
          >
            <path
              d="M10 15l5-3-5-3v6zM21.8 8s-.2-1.4-.8-2c-.7-.8-1.4-.8-1.7-.9C16.6 5 12 5 12 5h0s-4.6 0-7.3.1c-.3 0-1 .1-1.7.9-.6.6-.8 2-.8 2S2 9.6 2 11.2v1.6c0 1.6.2 3.2.2 3.2s.2 1.4.8 2c.7.8 1.7.8 2.1.9 1.5.1 6.9.1 6.9.1s4.6 0 7.3-.1c.3 0 1-.1 1.7-.9.6-.6.8-2 .8-2s.2-1.6.2-3.2v-1.6c0-1.6-.2-3.2-.2-3.2z"
            ></path>
          </svg>
        </a>

        <!-- Instagram CRILASROZAS -->
        <a
          href="https://www.instagram.com/crilasrozas?igsh=dHo5Z2JicGJpNTRp"
          target="_blank"
          class="flex items-center justify-center w-12 h-12 bg-pink-500 hover:bg-pink-600 text-white rounded-full transition"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-6 h-6"
            fill="white"
            viewBox="0 0 24 24"
          >
            <path
              d="M7.75 2h8.5C19.55 2 22 4.45 22 7.75v8.5C22 19.55 19.55 22 16.25 22h-8.5C4.45 22 2 19.55 2 16.25v-8.5C2 4.45 4.45 2 7.75 2zm0 1.5C5.68 3.5 4 5.18 4 7.25v9.5C4 18.32 5.68 20 7.75 20h8.5c2.07 0 3.75-1.68 3.75-3.75v-9.5C20 5.68 18.32 3.5 16.25 3.5h-8.5zm4.25 2a5.5 5.5 0 110 11 5.5 5.5 0 010-11zm0 1.5a4 4 0 100 8 4 4 0 000-8zm5-2a1 1 0 110 2 1 1 0 010-2z"
            ></path>
          </svg>
        </a>

        <!-- Instagram SAMUDELCRI -->
        <a
          href="https://www.instagram.com/samudelcri?igsh=MWxnM2ltZDc3cHQ2ag=="
          target="_blank"
          class="flex items-center justify-center w-12 h-12 bg-pink-500 hover:bg-pink-600 text-white rounded-full transition"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-6 h-6"
            fill="white"
            viewBox="0 0 24 24"
          >
            <path
              d="M7.75 2h8.5C19.55 2 22 4.45 22 7.75v8.5C22 19.55 19.55 22 16.25 22h-8.5C4.45 22 2 19.55 2 16.25v-8.5C2 4.45 4.45 2 7.75 2zm0 1.5C5.68 3.5 4 5.18 4 7.25v9.5C4 18.32 5.68 20 7.75 20h8.5c2.07 0 3.75-1.68 3.75-3.75v-9.5C20 5.68 18.32 3.5 16.25 3.5h-8.5zm4.25 2a5.5 5.5 0 110 11 5.5 5.5 0 010-11zm0 1.5a4 4 0 100 8 4 4 0 000-8zm5-2a1 1 0 110 2 1 1 0 010-2z"
            ></path>
          </svg>
        </a>

        <!-- Instagram CORRECONSAMU -->
        <a
          href="https://www.instagram.com/correconsamu?igsh=bnJ2MnczZ2llcmVl"
          target="_blank"
          class="flex items-center justify-center w-12 h-12 bg-pink-500 hover:bg-pink-600 text-white rounded-full transition"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-6 h-6"
            fill="white"
            viewBox="0 0 24 24"
          >
            <path
              d="M7.75 2h8.5C19.55 2 22 4.45 22 7.75v8.5C22 19.55 19.55 22 16.25 22h-8.5C4.45 22 2 19.55 2 16.25v-8.5C2 4.45 4.45 2 7.75 2zm0 1.5C5.68 3.5 4 5.18 4 7.25v9.5C4 18.32 5.68 20 7.75 20h8.5c2.07 0 3.75-1.68 3.75-3.75v-9.5C20 5.68 18.32 3.5 16.25 3.5h-8.5zm4.25 2a5.5 5.5 0 110 11 5.5 5.5 0 010-11zm0 1.5a4 4 0 100 8 4 4 0 000-8zm5-2a1 1 0 110 2 1 1 0 010-2z"
            ></path>
          </svg>
        </a>

        <!-- Blog personal -->
        <a
          href="https://centrorehabilitacionintegral.blogspot.com/?m=1"
          target="_blank"
          class="flex items-center justify-center w-12 h-12 bg-yellow-500 hover:bg-yellow-600 text-white rounded-full transition"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-6 h-6"
            fill="white"
            viewBox="0 0 24 24"
          >
            <path d="M4 4h16v16H4V4zm2 2v12h12V6H6zm2 2h8v2H8V8zm0 4h8v2H8v-2z"
            ></path>
          </svg>
        </a>

        <!-- Strava -->
        <a
          href="https://strava.app.link/94JqvdpQ20b"
          target="_blank"
          class="flex items-center justify-center w-12 h-12 bg-orange-500 hover:bg-orange-600 text-white rounded-full transition"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-6 h-6"
            fill="white"
            viewBox="0 0 24 24"
          >
            <path d="M2 22l6-18 3 9 4-12 5 21-18-0z"></path>
          </svg>
        </a>

        <!-- X / Twitter SAMU -->
        <a
          href="https://x.com/crilasrozas"
          target="_blank"
          class="flex items-center justify-center w-12 h-12 bg-blue-700 hover:bg-blue-800 text-white rounded-full transition"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-6 h-6"
            fill="white"
            viewBox="0 0 24 24"
          >
            <path
              d="M22 4.01c-.77.35-1.6.58-2.47.69a4.33 4.33 0 001.89-2.38 8.72 8.72 0 01-2.75 1.05 4.31 4.31 0 00-7.35 3.93A12.22 12.22 0 013 5.16a4.31 4.31 0 001.33 5.75 4.27 4.27 0 01-1.95-.54v.05a4.31 4.31 0 003.45 4.22 4.33 4.33 0 01-1.94.07 4.32 4.32 0 004.03 2.99 8.64 8.64 0 01-5.35 1.84A8.77 8.77 0 012 19.54a12.2 12.2 0 006.6 1.94c7.92 0 12.25-6.56 12.25-12.25 0-.19-.01-.38-.02-.57A8.73 8.73 0 0022 4.01z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
