---
// fisioterapia.astro
import BaseLayout from '../layouts/BaseLayout.astro';
//const base = import.meta.env.BASE_URL;
---

<BaseLayout>
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-3xl font-semibold text-center mb-12">Servicios de Fisioterapia</h2>

      <div class="grid md:grid-cols-2 gap-10">
        <div class="bg-gray-50 p-8 rounded-xl shadow-md">
          <h3 class="text-xl font-semibold mb-4">Lesiones deportivas</h3>
          <p>Recuperación de lesiones musculares, tendinopatías y postquirúrgicas con tratamiento individualizado.</p>
        </div>

        <div class="bg-gray-50 p-8 rounded-xl shadow-md">
          <h3 class="text-xl font-semibold mb-4">Dolor cervical y lumbar</h3>
          <p>Tratamiento personalizado para molestias crónicas y sobrecargas musculares.</p>
        </div>

        <div class="bg-gray-50 p-8 rounded-xl shadow-md">
          <h3 class="text-xl font-semibold mb-4">Rehabilitación postoperatoria</h3>
          <p>Plan de recuperación progresivo para volver a la actividad deportiva o diaria de manera segura.</p>
        </div>

        <div class="bg-gray-50 p-8 rounded-xl shadow-md">
          <h3 class="text-xl font-semibold mb-4">Electroterapia y técnicas avanzadas</h3>
          <p>Uso de tecnología avanzada para acelerar la recuperación y aliviar el dolor.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>