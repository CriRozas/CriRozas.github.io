---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
//const base = import.meta.env.BASE_URL;
---

<BaseLayout>
  <!-- Hero Section -->
  <section class="relative bg-gray-50">
    <div class="max-w-6xl mx-auto px-6 py-20 flex flex-col-reverse md:flex-row items-center gap-12">
      
      <!-- Texto Principal -->
      <div class="flex-1 text-center md:text-left">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">CRI las Rozas</h1>
        <p class="text-gray-700 mb-6">
          Especialistas en <span class="font-semibold">fisioterapia deportiva</span> y 
          <span class="font-semibold">psicología</span>. Tratamientos personalizados para deportistas y cualquier persona que busque bienestar y recuperación.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
          <a href="/contacto" class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-lg font-medium transition">
            Reserva tu cita
          </a>
          <a href="/precios" class="bg-gray-200 hover:bg-gray-300 text-gray-800 px-8 py-3 rounded-lg font-medium transition">
            Ver precios
          </a>
        </div>
      </div>
      
      <!-- Imagen -->
      <div class="flex-1 flex justify-center md:justify-end">
        <img src="/assets/hero-fisio.png" alt="Fisioterapeuta Crilas Rozas" class="rounded-xl shadow-lg w-full max-w-md" />
      </div>

    </div>
  </section>

  <!-- JSON-LD para SEO -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "MedicalBusiness",
    "name": "CRI las Rozas",
    "image": "https://CriRozas.github.io/assets/logo.jpg",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Dirección exacta",
      "addressLocality": "Las Rozas",
      "addressRegion": "Madrid",
      "postalCode": "28231",
      "addressCountry": "ES"
    },
    "telephone": "+34 674 26 61 91",
    "priceRange": "€€"
  }
  </script>
</BaseLayout>