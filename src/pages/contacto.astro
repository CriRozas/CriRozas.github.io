---
// src/pages/contacto.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section class="py-20 bg-white" id="contacto">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-semibold mb-12">Contacto</h2>

      <p class="mb-6 text-gray-700">
        Teléfono: <a href="tel:+34674266191" class="text-blue-600 font-semibold">+34 674 26 61 91</a>
      </p>

      <p class="mb-6 text-gray-700">
        Email:
        <a href="mailto:centrorehabilitacionintegral@gmail.com" class="text-blue-600 font-semibold">
          centrorehabilitacionintegral@gmail.com
        </a>
      </p>

      <p class="mb-6 text-gray-700">
        Dirección:
        <a
          href="https://www.google.com/maps/dir//CRI+LAS+ROZAS+%22Centro+de+Rehabilitaci%C3%B3n+Integral%22+.,+C%2FDE+LA+ESTACION,+22,+28231+Las+Rozas+de+Madrid,+Madrid/@40.4946661,-3.8749155,15.5z/data=!4m17!1m7!3m6!1s0xd41837941856ab9:0xcd42ae59964a50ad!2sCRI+LAS+ROZAS+%22Centro+de+Rehabilitaci%C3%B3n+Integral%22+.!8m2!3d40.495018!4d-3.8695894!16s%2Fg%2F1tx48bh5!4m8!1m0!1m5!1m1!1s0xd41837941856ab9:0xcd42ae59964a50ad!2m2!1d-3.869585!2d40.4950097!3e0?entry=ttu&g_ep=EgoyMDI2MDIxNi4wIKXMDSoASAFQAw%3D%3D"
          target="_blank"
          class="text-blue-600 font-semibold hover:underline"
        >
          C/DE LA ESTACION, 22, 28231 Las Rozas de Madrid, Madrid
        </a>
      </p>

      <div class="flex justify-center gap-4 mb-8 flex-wrap">
        <!-- WhatsApp -->
        <a href="https://wa.me/34674266191" target="_blank"
           class="flex items-center justify-center w-12 h-12 bg-green-500 hover:bg-green-600 text-white rounded-full transition">
