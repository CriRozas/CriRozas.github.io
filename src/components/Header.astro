---
const base = import.meta.env.BASE_URL;
---

<header class="fixed top-0 w-full bg-white shadow z-50">
  <nav class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">

    <!-- LOGO -->
    <a href={`${base}`} class="flex items-center">
      <img src={`${base}assets/logo.jpeg`} alt="CRI las Rozas" class="h-12 w-auto">
      <span class="ml-2 font-bold text-xl text-gray-800">CRI las Rozas</span>
    </a>

    <!-- MENÚ DESKTOP -->
    <ul class="hidden lg:flex space-x-6 text-gray-700 font-semibold items-center">
      <li><a href={`${base}`} class="hover:text-blue-600">Inicio</a></li>
      <li><a href={`${base}experiencia/`} class="hover:text-blue-600">Experiencia</a></li>
      <li><a href={`${base}galeria/`} class="hover:text-blue-600">Momentos destacados</a></li>
      <li><a href={`${base}fisioterapia/`} class="hover:text-blue-600">Fisioterapia</a></li>
      <li><a href={`${base}psicologia/`} class="hover:text-blue-600">Psicología</a></li>
      <li><a href={`${base}precios/`} class="hover:text-blue-600">Precios</a></li>
      <li><a href={`${base}diferenciales/`} class="hover:text-blue-600">Por qué elegirnos</a></li>
      <li><a href={`${base}entrena/`} class="hover:text-blue-600">Entrenamientos</a></li>
      <li><a href={`${base}contacto/`} class="hover:text-blue-600">Contacto</a></li>
    </ul>

    <!-- BOTÓN MÓVIL -->
    <div class="lg:hidden">
      <button id="menu-btn" class="text-gray-700 focus:outline-none">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

  </nav>

  <!-- MENÚ MÓVIL -->
  <ul id="mobile-menu"
      class="lg:hidden hidden flex-col space-y-4 px-6 pb-4 text-gray-700 font-semibold bg-white">
    <li><a href={`${base}`} class="hover:text-blue-600">Inicio</a></li>
    <li><a href={`${base}experiencia/`} class="hover:text-blue-600">Experiencia</a></li>
    <li><a href={`${base}galeria/`} class="hover:text-blue-600">Momentos destacados</a></li>
    <li><a href={`${base}fisioterapia/`} class="hover:text-blue-600">Fisioterapia</a></li>
    <li><a href={`${base}psicologia/`} class="hover:text-blue-600">Psicología</a></li>
    <li><a href={`${base}precios/`} class="hover:text-blue-600">Precios</a></li>
    <li><a href={`${base}diferenciales/`} class="hover:text-blue-600">Por qué elegirnos</a></li>
    <li><a href={`${base}entrena/`} class="hover:text-blue-600">Entrenamientos</a></li>
    <li><a href={`${base}contacto/`} class="hover:text-blue-600">Contacto</a></li>
  </ul>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>