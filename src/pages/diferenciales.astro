---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section class="py-20 bg-gray-100" id="diferenciales">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-3xl font-semibold text-center mb-12">Por qué elegirnos</h2>

      <div class="grid md:grid-cols-3 gap-10 text-center">
        <div class="p-8 bg-white rounded-xl shadow-md">
          <h3 class="text-xl font-semibold mb-4">Experiencia internacional</h3>
          <p>Juegos Olímpicos y clubes profesionales aplicando experiencia a cada paciente.</p>
        </div>

        <div class="p-8 bg-white rounded-xl shadow-md">
          <h3 class="text-xl font-semibold mb-4">Trato cercano</h3>
          <p>Atención personalizada y adaptada a tus necesidades, con cercanía y profesionalidad.</p>
        </div>

        <div class="p-8 bg-white rounded-xl shadow-md">
          <h3 class="text-xl font-semibold mb-4">Resultados comprobados</h3>
          <p>Recuperaciones rápidas y seguras, avaladas por años de experiencia en deporte y salud.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>